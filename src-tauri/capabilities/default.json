{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop permissions for the main 3DV window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:read-files",
    {
      "identifier": "fs:scope",
      "allow": ["**/*"]
    }
  ]
}
